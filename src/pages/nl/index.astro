---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import yaml from 'js-yaml';
import Base from '../../layouts/Base.astro';
import Comparator from '../../components/Comparator.astro';
import type { Product } from '../../types';
import t from '../../i18n/nl.json';

const yamlPath = fileURLToPath(new URL('../../data/products.yaml', import.meta.url));
const productsRaw = yaml.load(readFileSync(yamlPath, 'utf8')) as Product[];
---

<Base title={t.siteName} description={t.siteDesc} lang="nl">
  <Comparator
    t={t}
    products={productsRaw}
    locale="nl"
    altLocale="de"
    altUrl="/de/"
  />
</Base>
